{
  "name": "@fsavio/boleto-utils",
  "version": "0.0.2",
  "main": "index.js",
  "types": "index.d.ts",
  "description": "Javascript bindings for Rust crate `boleto-utils`.",
  "homepage": "https://github.com/fernandosavio/boleto-utils-js#readme",
  "bugs": {
    "url": "https://github.com/fernandosavio/boleto-utils-js/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Fernando Sávio",
    "url": "https://github.com/fernandosavio"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/fernandosavio/boleto-utils-js"
  },
  "keywords": [
    "boleto",
    "código de barras",
    "barcode",
    "linha digitável",
    "digitable line",
    "cobrança",
    "arrecadação",
    "convênio",
    "npc"
  ],
  "napi": {
    "name": "boleto-utils",
    "triples": {
      "additional": [
        "aarch64-apple-darwin",
        "aarch64-linux-android",
        "aarch64-unknown-linux-gnu",
        "aarch64-unknown-linux-musl",
        "aarch64-pc-windows-msvc",
        "armv7-unknown-linux-gnueabihf",
        "x86_64-unknown-linux-musl",
        "x86_64-unknown-freebsd",
        "i686-pc-windows-msvc",
        "armv7-linux-androideabi",
        "universal-apple-darwin"
      ]
    }
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.16.3",
    "ava": "^5.1.1"
  },
  "ava": {
    "timeout": "3m"
  },
  "engines": {
    "node": ">= 14"
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "prepublishOnly": "napi prepublish -t npm",
    "test": "ava",
    "universal": "napi universal",
    "version": "napi version"
  },
  "packageManager": "yarn@3.6.3",
  "optionalDependencies": {
    "@fsavio/boleto-utils-win32-x64-msvc": "0.0.1",
    "@fsavio/boleto-utils-darwin-x64": "0.0.1",
    "@fsavio/boleto-utils-linux-x64-gnu": "0.0.1",
    "@fsavio/boleto-utils-darwin-arm64": "0.0.1",
    "@fsavio/boleto-utils-android-arm64": "0.0.1",
    "@fsavio/boleto-utils-linux-arm64-gnu": "0.0.1",
    "@fsavio/boleto-utils-linux-arm64-musl": "0.0.1",
    "@fsavio/boleto-utils-win32-arm64-msvc": "0.0.1",
    "@fsavio/boleto-utils-linux-arm-gnueabihf": "0.0.1",
    "@fsavio/boleto-utils-linux-x64-musl": "0.0.1",
    "@fsavio/boleto-utils-freebsd-x64": "0.0.1",
    "@fsavio/boleto-utils-win32-ia32-msvc": "0.0.1",
    "@fsavio/boleto-utils-android-arm-eabi": "0.0.1",
    "@fsavio/boleto-utils-darwin-universal": "0.0.1"
  }
}
